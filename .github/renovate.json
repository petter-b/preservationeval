{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":approveMajorUpdates",
    ":automergeMinor",
    ":automergeRequireAllStatusChecks",
    ":enableVulnerabilityAlerts",
    ":ignoreUnstable"
  ],
  "minimumReleaseAge": "14 days",
  "timezone": "Europe/Stockholm",
  "schedule": ["* 13-17 * * 5"],
  "packageRules": [
    {
      "description": "Real runtime/production dependencies (minor/patch) from pyproject.toml",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin"
      ],
      "automerge": true,
      "labels": ["release-patch"]
    },
    {
      "description": "Real runtime/production dependencies (major) from pyproject.toml",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "automerge": false
    },
    {
      "description": "Other runtime/production dependencies (minor/patch)",
      "matchManagers": ["npm"],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin"
      ],
      "automerge": true,
      "labels": ["release-patch"]
    },
    {
      "description": "Other real runtime/production dependencies (major)",
      "matchManagers": ["npm"],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "automerge": false
    },
    {
      "description": "Group CI/build tooling (GitHub Actions, pep621 dev deps)",
      "matchManagers": [
        "pep621",
        "github-actions"
      ],
      "groupName": "Update CI/build dependencies",
      "automerge": true,
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin"
      ]
    },
    {
      "description": "Devcontainer updates (Python version, features) — separate PR",
      "matchManagers": ["devcontainer"],
      "automerge": false,
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin"
      ]
    }
  ]
}
